<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="RobustFiler.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:RobustFiler"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="RobustFiler"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="RobustFiler">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
            <TitleBar.Content>
                <Grid HorizontalAlignment="Right">
                    <Button Command="{x:Bind ViewModel.ToggleDualPaneCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="46" Height="32"
                            ToolTipService.ToolTip="デュアルペイン">
                        <SymbolIcon Symbol="TwoPage" />
                    </Button>
                </Grid>
            </TitleBar.Content>
        </TitleBar>

        <!--
            The Frame hosts pages for your application content. Add your UI to
            MainPage.xaml rather than here so you can use Page features such as
            navigation events and the Loaded lifecycle.
        -->
        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>
</Window>
