<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="RobustFiler.MainPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:viewmodels="using:RobustFiler.ViewModels"
    xmlns:models="using:RobustFiler.Models"
    xmlns:controls="using:RobustFiler.Controls"
    xmlns:converters="using:RobustFiler.Converters"
    xmlns:sizers="using:CommunityToolkit.WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="TrueToVisibleConverter" Invert="False" />
        <converters:BoolToVisibilityConverter x:Key="FalseToVisibleConverter" Invert="True" />
    </Page.Resources>

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" MaxWidth="500" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Favorites Panel -->
            <Grid Grid.Column="0" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="お気に入り" FontWeight="SemiBold" Margin="16,12,16,8" />
                
                <ListView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.Favorites, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedFavorite, Mode=TwoWay}"
                          SelectionMode="Single"
                          ShowsScrollingPlaceholders="False">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:FavoriteItem">
                            <StackPanel Orientation="Horizontal" Spacing="12" Padding="4">
                                <Image Source="{x:Bind Icon, Mode=OneWay}" Width="16" Height="16" VerticalAlignment="Center" />
                                <TextBlock Text="{x:Bind Name, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind Path}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="ContextFlyout">
                                <Setter.Value>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="お気に入りから削除" 
                                                        Command="{Binding ElementName=RootPage, Path=ViewModel.RemoveFavoriteCommand}"
                                                        CommandParameter="{Binding}" />
                                    </MenuFlyout>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>

            <sizers:GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent" Width="8" />

            <TabView Grid.Column="2" 
                     TabItemsSource="{x:Bind ViewModel.Tabs, Mode=OneWay}" 
                     SelectedItem="{x:Bind ViewModel.SelectedTab, Mode=TwoWay}"
                     AddTabButtonClick="TabView_AddTabButtonClick"
                     TabCloseRequested="TabView_TabCloseRequested"
                     IsAddTabButtonVisible="True">
                <TabView.TabItemTemplate>
                    <DataTemplate x:DataType="viewmodels:TabItemViewModel">
                        <TabViewItem Header="{x:Bind Header, Mode=OneWay}">
                            <TabViewItem.Content>
                                <Grid>
                                    <!-- Single Pane -->
                                    <controls:FilePaneControl DataContext="{x:Bind PrimaryPane}" 
                                                              Visibility="{x:Bind IsDualPane, Mode=OneWay, Converter={StaticResource FalseToVisibleConverter}}" />
                                    
                                    <!-- Dual Pane -->
                                    <Grid Visibility="{x:Bind IsDualPane, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <controls:FilePaneControl Grid.Column="0" DataContext="{x:Bind PrimaryPane}" />
                                        <sizers:GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent" />
                                        <controls:FilePaneControl Grid.Column="2" DataContext="{x:Bind SecondaryPane, Mode=OneWay}" />
                                    </Grid>
                                </Grid>
                            </TabViewItem.Content>
                        </TabViewItem>
                    </DataTemplate>
                </TabView.TabItemTemplate>
            </TabView>
        </Grid>
    </Grid>
</Page>
