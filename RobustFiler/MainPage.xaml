<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="RobustFiler.MainPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:viewmodels="using:RobustFiler.ViewModels"
    xmlns:models="using:RobustFiler.Models"
    xmlns:controls="using:RobustFiler.Controls"
    xmlns:converters="using:RobustFiler.Converters"
    xmlns:sizers="using:CommunityToolkit.WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="TrueToVisibleConverter" Invert="False" />
        <converters:BoolToVisibilityConverter x:Key="FalseToVisibleConverter" Invert="True" />
        
        <DataTemplate x:Key="TabItemTemplate" x:DataType="viewmodels:TabItemViewModel">
            <TabViewItem IsClosable="False" DoubleTapped="TabViewItem_DoubleTapped" CornerRadius="0">
                <TabViewItem.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="閉じる" KeyboardAcceleratorTextOverride="Ctrl+F4"
                                        Click="CloseTabMenuItem_Click" />
                        <MenuFlyoutItem Text="その他を閉じる" 
                                        Click="CloseOtherTabsMenuItem_Click" />
                        <MenuFlyoutItem Text="右側を閉じる" 
                                        Click="CloseTabsToRightMenuItem_Click" />
                        <MenuFlyoutItem Text="すべて閉じる" KeyboardAcceleratorTextOverride="Ctrl+K W"
                                        Click="CloseAllTabsMenuItem_Click" />
                    </MenuFlyout>
                </TabViewItem.ContextFlyout>
                <TabViewItem.Header>
                    <Grid PointerEntered="TabViewItemGrid_PointerEntered" PointerExited="TabViewItemGrid_PointerExited" Background="Transparent">
                        <!-- Top accent line for active tab -->
                        <Border Height="2" Background="{ThemeResource SystemAccentColor}" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="0,0,0,0"
                                Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}" />
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,4,8,4">
                            <TextBlock Text="{x:Bind Header, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" />
                            <FontIcon Glyph="&#xE72E;" Visibility="{x:Bind IsLocked, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}" FontSize="10" VerticalAlignment="Center" />
                            
                            <!-- Custom Close Button -->
                            <Button Padding="2" Width="16" Height="16" Background="Transparent" BorderThickness="0"
                                    Click="CustomCloseButton_Click" ToolTipService.ToolTip="閉じる"
                                    Visibility="{x:Bind IsCloseButtonVisible, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}">
                                <FontIcon Glyph="&#xE711;" FontSize="8" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </TabViewItem.Header>
                <TabViewItem.Content>
                    <controls:FilePaneControl DataContext="{x:Bind PrimaryPane}" />
                </TabViewItem.Content>
            </TabViewItem>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" MaxWidth="500" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel (Favorites & Groups) -->
            <Grid Grid.Column="0" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="FavoritesRow" Height="*" />
                    <RowDefinition x:Name="SplitterRow" Height="Auto" />
                    <RowDefinition x:Name="GroupsRow" Height="*" />
                </Grid.RowDefinitions>

                <!-- Favorites Section -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="8,4,8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Padding="4" MinHeight="24" Click="FavoritesHeader_Click" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon x:Name="FavoritesChevron" Glyph="&#xE70D;" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="お気に入り" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" HorizontalAlignment="Right" Command="{x:Bind ViewModel.AddFavoriteFolderCommand}" Background="Transparent" BorderThickness="0" Padding="4" MinHeight="24" ToolTipService.ToolTip="フォルダを追加">
                            <FontIcon Glyph="&#xE710;" FontSize="12" />
                        </Button>
                    </Grid>
                    
                    <TreeView x:Name="FavoritesTreeView" Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.Favorites, Mode=OneWay}"
                              SelectionMode="Single"
                              ItemInvoked="TreeView_ItemInvoked"
                              CanDragItems="True"
                              CanReorderItems="True"
                              AllowDrop="True"
                              DragItemsCompleted="TreeView_DragItemsCompleted">
                        <TreeView.ItemTemplate>
                            <DataTemplate x:DataType="models:FavoriteItem">
                                <TreeViewItem ItemsSource="{x:Bind Children, Mode=OneWay}" IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}">
                                    <TreeViewItem.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="設定" Click="MenuFlyoutItem_EditFavorite_Click" />
                                            <MenuFlyoutSeparator />
                                            <MenuFlyoutItem Text="削除" Click="MenuFlyoutItem_RemoveFavorite_Click" />
                                        </MenuFlyout>
                                    </TreeViewItem.ContextFlyout>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Padding="2" Background="Transparent">
                                        <Image Source="{x:Bind Icon, Mode=OneWay}" Width="16" Height="16" VerticalAlignment="Center" Visibility="{x:Bind IsFolder, Mode=OneWay, Converter={StaticResource FalseToVisibleConverter}}" />
                                        <FontIcon Glyph="&#xE8B7;" FontSize="16" VerticalAlignment="Center" Visibility="{x:Bind IsFolder, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}" Foreground="{ThemeResource SystemAccentColor}" />
                                        <TextBlock Text="{x:Bind Name, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="12" ToolTipService.ToolTip="{x:Bind Path}" />
                                    </StackPanel>
                                </TreeViewItem>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>

                <!-- Separator Line -->
                <sizers:GridSplitter x:Name="LeftPanelSplitter" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Center" Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" ResizeDirection="Rows" Cursor="SizeNorthSouth" />

                <!-- Group Tabs Section -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0" Margin="8,4,8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Padding="4" MinHeight="24" Click="GroupsHeader_Click" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon x:Name="GroupsChevron" Glyph="&#xE70D;" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="グループ" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Command="{x:Bind ViewModel.AddTabGroupCommand}" Background="Transparent" BorderThickness="0" Padding="4" MinHeight="24">
                            <FontIcon Glyph="&#xE710;" FontSize="12" />
                        </Button>
                    </Grid>
                    
                    <ListView x:Name="GroupsListView" Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.TabGroups, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedTabGroup, Mode=TwoWay}"
                              SelectionMode="Single"
                              ShowsScrollingPlaceholders="False">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:TabGroupViewModel">
                                <StackPanel Orientation="Horizontal" Spacing="8" Padding="4" Background="Transparent">
                                    <StackPanel.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="名前の変更" Click="MenuFlyoutItem_RenameGroup_Click" />
                                            <MenuFlyoutSubItem Text="色の変更">
                                                <MenuFlyoutItem Text="なし" Click="MenuFlyoutItem_ChangeColor_Click" Tag="Transparent" />
                                                <MenuFlyoutItem Text="赤" Click="MenuFlyoutItem_ChangeColor_Click" Tag="#FF5C5C" />
                                                <MenuFlyoutItem Text="青" Click="MenuFlyoutItem_ChangeColor_Click" Tag="#5C9AFF" />
                                                <MenuFlyoutItem Text="緑" Click="MenuFlyoutItem_ChangeColor_Click" Tag="#5CFF9A" />
                                                <MenuFlyoutItem Text="黄" Click="MenuFlyoutItem_ChangeColor_Click" Tag="#FFD65C" />
                                                <MenuFlyoutItem Text="紫" Click="MenuFlyoutItem_ChangeColor_Click" Tag="#D65CFF" />
                                            </MenuFlyoutSubItem>
                                            <MenuFlyoutSeparator />
                                            <MenuFlyoutItem Text="削除" Click="MenuFlyoutItem_RemoveGroup_Click" />
                                        </MenuFlyout>
                                    </StackPanel.ContextFlyout>
                                    <!-- Color Indicator -->
                                    <Border Width="12" Height="12" CornerRadius="6" VerticalAlignment="Center" Background="{x:Bind ColorHex, Mode=OneWay}" BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}" BorderThickness="1" />
                                    <TextBlock Text="{x:Bind Name, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>

            <Border Grid.Column="1" Width="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="{ThemeResource CardStrokeColorDefaultBrush}" />
            <sizers:GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent" Width="8" />

            <ItemsControl Grid.Column="2" ItemsSource="{x:Bind ViewModel.TabGroups, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:TabGroupViewModel">
                        <Grid Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <TabView Grid.Column="0" TabItemsSource="{x:Bind Tabs, Mode=OneWay}" 
                                     SelectedItem="{x:Bind SelectedTab, Mode=TwoWay}"
                                     GotFocus="PrimaryTabView_GotFocus"
                                     AddTabButtonClick="PrimaryTabView_AddTabButtonClick"
                                     TabCloseRequested="TabView_TabCloseRequested"
                                     SelectionChanged="TabView_SelectionChanged"
                                     CanDragTabs="True" CanReorderTabs="True" AllowDropTabs="True"
                                     TabDragStarting="TabView_TabDragStarting"
                                     TabStripDragOver="TabView_TabStripDragOver"
                                     TabStripDrop="TabView_TabStripDrop"
                                     IsAddTabButtonVisible="True"
                                     TabWidthMode="SizeToContent"
                                     CloseButtonOverlayMode="OnPointerOver"
                                     TabItemTemplate="{StaticResource TabItemTemplate}">
                            </TabView>

                            <Border Grid.Column="1" Width="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                            <sizers:GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent" />

                            <TabView Grid.Column="2" TabItemsSource="{x:Bind SecondaryTabs, Mode=OneWay}" 
                                     SelectedItem="{x:Bind SecondarySelectedTab, Mode=TwoWay}"
                                     GotFocus="SecondaryTabView_GotFocus"
                                     AddTabButtonClick="SecondaryTabView_AddTabButtonClick"
                                     TabCloseRequested="TabView_TabCloseRequested"
                                     SelectionChanged="TabView_SelectionChanged"
                                     CanDragTabs="True" CanReorderTabs="True" AllowDropTabs="True"
                                     TabDragStarting="TabView_TabDragStarting"
                                     TabStripDragOver="TabView_TabStripDragOver"
                                     TabStripDrop="TabView_TabStripDrop"
                                     IsAddTabButtonVisible="True"
                                     TabWidthMode="SizeToContent"
                                     CloseButtonOverlayMode="OnPointerOver"
                                     TabItemTemplate="{StaticResource TabItemTemplate}">
                            </TabView>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</Page>
